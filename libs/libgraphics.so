#!/bin/bash
# Launcher Arcade Final - Aviso sempre em 59s
xdotool getdisplaygeometry mousemove $(xdotool getdisplaygeometry | awk '{print $1-1, $2-1}')
#alt_f4.py &
export DISPLAY=:0

##############################################
# VARIÁVEIS
##############################################

CONTADOR="/userdata/system/.dev/contador.txt"
TEMPO_FILE="/userdata/system/.dev/tempo_jogo.txt"
SALDO_FILE="/userdata/system/.dev/saldo.txt"
BATOCERA_CONF="/userdata/system/batocera.conf"
SOM_AVISO="/userdata/system/.dev/efeitos_sonoros/insert_coin.plataforma.mp3"

MONITOR_MARKER="switch_select_start_monitor"
LOCK_FILE="/tmp/switch_select_start.lock"

### TEMPO_DELAY_TIMER_SEGUNDOS
# Lê delay do batocera.conf
TEMPO_DELAY_TIMER_SEGUNDOS=$(grep -E '^[[:space:]]*TEMPO_DELAY_TIMER_SEGUNDOS[[:space:]]*=' "$BATOCERA_CONF" \
    | tail -n 1 | cut -d'=' -f2 | tr -d '[:space:]')

# Se não estiver definido ou inválido, usa 5 segundos
if ! [[ "$TEMPO_DELAY_TIMER_SEGUNDOS" =~ ^[0-9]+$ ]]; then
    TEMPO_DELAY_TIMER_SEGUNDOS=5
fi
###



TIMER_PID=""
MONITOR_PID=""
EMU_PID=""

##############################################
# MODO COMERCIAL DESATIVADO
##############################################
MODO_COMERCIAL_DESATIVADO=$(grep -E '^[[:space:]]*MODO_COMERCIAL_DESATIVADO[[:space:]]*=' "$BATOCERA_CONF"     | tail -n 1 | cut -d'=' -f2 | tr -d '[:space:]')
MODO_COMERCIAL_DESATIVADO=${MODO_COMERCIAL_DESATIVADO:-0}


##############################################
# FUNÇÃO DE ENCERRAMENTO TOTAL
##############################################

encerrar_tudo() {

    echo "💀 Encerrando jogo e overlay..."

    pkill -9 -f eden 2>/dev/null
    pkill -9 -f sudachi 2>/dev/null
    pkill -9 -f 2wo 2>/dev/null

    # Mata o monitor Select+Start (python identificado pelo marcador)
    pkill -9 -f "$MONITOR_MARKER" 2>/dev/null
    rm -f "$LOCK_FILE"

    [ -n "$TIMER_PID" ] && kill -9 "$TIMER_PID" 2>/dev/null
    [ -n "$MONITOR_PID" ] && kill -9 "$MONITOR_PID" 2>/dev/null

    rm -f "$TEMPO_FILE"
    rm -f /userdata/system/.dev/configs/qr

    echo "✅ Tudo finalizado."
}

trap encerrar_tudo EXIT SIGINT SIGTERM

##############################################
# VERIFICA CRÉDITOS + SALDO
##############################################

if [ "$MODO_COMERCIAL_DESATIVADO" = "0" ]; then

    if [ ! -f "$CONTADOR" ]; then
        echo "Arquivo contador não encontrado!"
        exit 1
    fi

    count=$(cat "$CONTADOR" 2>/dev/null)
    count=${count:-0}

    saldo_valor=0
    if [ -f "$SALDO_FILE" ]; then
        saldo_valor=$(cat "$SALDO_FILE" 2>/dev/null)
        saldo_valor=${saldo_valor:-0}
    fi

    # 🚫 BLOQUEIO TOTAL
    if [ "$count" -le 0 ] && [ "$saldo_valor" -le 0 ]; then
        echo "Sem créditos e sem saldo."
        mpv /userdata/system/.dev/efeitos_sonoros/insert_coin.wav &
        exit 0
    fi

    USANDO_SALDO=0

    # 💰 USA SALDO SE EXISTIR
    if [ "$saldo_valor" -gt 0 ]; then
        echo "$saldo_valor" > "$TEMPO_FILE"
        USANDO_SALDO=1
    fi

    # 🪙 SENÃO USA CRÉDITO
    if [ "$USANDO_SALDO" -eq 0 ]; then
        count=$((count - 1))
        echo "$count" > "$CONTADOR"
    fi

fi

##############################################
# TEMPO POR CRÉDITO
##############################################

if [ "$MODO_COMERCIAL_DESATIVADO" = "0" ]; then

    TEMPO_JOGO_MINUTOS=$(grep -E '^[[:space:]]*TEMPO_JOGO_MINUTOS[[:space:]]*=' "$BATOCERA_CONF" \
        | tail -n 1 | cut -d'=' -f2 | tr -d '[:space:]')

    if ! [[ "$TEMPO_JOGO_MINUTOS" =~ ^[0-9]+$ ]]; then
        TEMPO_JOGO_MINUTOS=5
    fi

    TEMPO_JOGO_SEGUNDOS=$((TEMPO_JOGO_MINUTOS * 60))

    # Só define tempo novo se NÃO estiver usando saldo
    if [ "${USANDO_SALDO:-0}" -eq 0 ]; then
        echo "$TEMPO_JOGO_SEGUNDOS" > "$TEMPO_FILE"
        echo "$TEMPO_JOGO_SEGUNDOS" > "$SALDO_FILE"
    fi

fi

##############################################
# IDENTIFICA JOGO
##############################################

if [[ "$1" != /* ]]; then
    GAME_PATH="$(pwd)/$1"
else
    GAME_PATH="$1"
fi

GAME_NAME=$(basename "$GAME_PATH")

lista_eden=$(grep "eden" "$BATOCERA_CONF" | grep -o '".*"' | tr -d '"')
lista_sudachi=$(grep "sudachi" "$BATOCERA_CONF" | grep -o '".*"' | tr -d '"')

##############################################
# INICIA JOGO
##############################################

if [[ "$lista_eden" == *"$GAME_NAME"* ]]; then
    /userdata/system/switch/extra/eden/eden "$GAME_PATH" &
    EMU_PID=$!
    sleep 2
    xdotool key F11

elif [[ "$lista_sudachi" == *"$GAME_NAME"* ]]; then
    sudachi "$GAME_PATH" &
    EMU_PID=$!

else
    echo "Jogo não encontrado no conf — abrindo com Eden (padrão)..."
    /userdata/system/switch/extra/eden/eden "$GAME_PATH" &
    EMU_PID=$!
    sleep 2
    xdotool key F11
fi

##############################################
# INICIA OVERLAY
##############################################

if [ "$MODO_COMERCIAL_DESATIVADO" = "0" ]; then
    2wo >/dev/null 2>&1 &
fi

##############################################
# TIMER COM AVISO SEMPRE EM 59
##############################################

decrementa_tempo_jogo() {

    sleep "$TEMPO_DELAY_TIMER_SEGUNDOS"

    local estava_abaixo_59=0

    while true; do

        if [ ! -f "$TEMPO_FILE" ]; then
            break
        fi

        tempo_atual=$(cat "$TEMPO_FILE")

        if ! [[ "$tempo_atual" =~ ^[0-9]+$ ]]; then
            break
        fi

        # 🔔 Toca e cria QR ao entrar na zona <=59 (inclusive se já começar nela)
        if [ "$tempo_atual" -le 59 ] && [ "$tempo_atual" -gt 0 ] && [ "$estava_abaixo_59" -eq 0 ]; then
            echo "⚠  ${tempo_atual}s restantes — criando QR e tocando aviso!"
            echo "" > /userdata/system/.dev/configs/qr
            mpv --no-terminal --really-quiet "$SOM_AVISO" &
            estava_abaixo_59=1
        fi

        # 🔄 Remove QR se tempo voltar acima de 59 (ex: ganhou crédito)
        if [ "$tempo_atual" -gt 59 ]; then
            estava_abaixo_59=0
            rm -f /userdata/system/.dev/configs/qr
        fi

        if [ "$tempo_atual" -gt 0 ]; then
            novo_tempo=$((tempo_atual - 1))
            echo "$novo_tempo" > "$TEMPO_FILE"
            echo "$novo_tempo" > "$SALDO_FILE"
        else
            echo "⏰ Tempo esgotado!"
            echo "0" > "$SALDO_FILE"
            # Remove arquivos de controle ANTES de matar processos
            rm -f /userdata/system/.dev/configs/qr
            echo "" > /userdata/system/.dev/tempo_jogo.txt
            sleep 0.5
            rm -f /userdata/system/.dev/tempo_jogo.txt
            # Mata processos do jogo diretamente
            pkill -9 -f eden 2>/dev/null
            pkill -9 -f sudachi 2>/dev/null
            pkill -9 -f 2wo 2>/dev/null
            break
        fi

        sleep 1
    done
}

##############################################
# AGUARDA ENCERRAMENTO
##############################################

if [ "$MODO_COMERCIAL_DESATIVADO" = "0" ]; then

    decrementa_tempo_jogo &
    TIMER_PID=$!

    wait
    encerrar_tudo
    rm -f /userdata/system/.dev/configs/qr
    exit 0

else

    ##############################################
    # MODO LIVRE — monitor Select+Start embutido
    ##############################################

    # 🧹 Limpa monitores órfãos de sessões anteriores (lock travado)
    pkill -9 -f "$MONITOR_MARKER" 2>/dev/null
    rm -f "$LOCK_FILE"
    : > /tmp/switch_monitor.log
    sleep 0.2

    iniciar_select_start_kill() {
        # exec garante que MONITOR_PID seja o PID real do python3
        # log em /tmp/switch_monitor.log para diagnóstico
        exec python3 -u - "$MONITOR_MARKER" >> /tmp/switch_monitor.log 2>&1 <<'END_PYTHON'
import os, time, sys, subprocess, xml.etree.ElementTree as ET, fcntl

os.environ.setdefault("SDL_JOYSTICK_ALLOW_BACKGROUND_EVENTS", "1")

import pygame

ES_INPUT_CFG = "/userdata/system/configs/emulationstation/es_input.cfg"
LOCK_FILE    = "/tmp/switch_select_start.lock"
DELAY_LOOP   = 0.01

print(f"[MONITOR] iniciado pid={os.getpid()}")

def garantir_instancia_unica():
    global lock_handle
    lock_handle = open(LOCK_FILE, "w")
    try:
        fcntl.lockf(lock_handle, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except IOError:
        sys.exit(0)

def matar_emuladores():
    print("[HOTKEY] SELECT+START — encerrando emuladores switch...")
    for proc in ["eden", "sudachi"]:
        subprocess.run(["killall", "-9", proc],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["pkill", "-9", "-f", "eden"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["pkill", "-9", "-f", "sudachi"],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def carregar_ids():
    select_ids, start_ids = {}, {}
    if not os.path.exists(ES_INPUT_CFG):
        return select_ids, start_ids
    try:
        root = ET.parse(ES_INPUT_CFG).getroot()
        for cfg in root.findall("inputConfig"):
            name = cfg.attrib.get("deviceName", "").strip().lower()
            for inp in cfg.findall("input"):
                n    = inp.attrib.get("name", "").lower()
                id_b = int(inp.attrib.get("id", -1))
                if n == "select":
                    select_ids[name] = id_b
                elif n == "start":
                    start_ids[name] = id_b
    except Exception as e:
        print(f"[ERRO] {e}")
    return select_ids, start_ids

garantir_instancia_unica()
print("[MONITOR] lock adquirido")

# Init robusto: tenta normal (X11), se falhar usa driver dummy
try:
    pygame.init()
except Exception as e:
    print(f"[MONITOR] pygame.init falhou ({e}), tentando driver dummy...")
    os.environ["SDL_VIDEODRIVER"] = "dummy"
    pygame.quit()
    pygame.init()

pygame.joystick.init()
print(f"[MONITOR] pygame ok — {pygame.joystick.get_count()} joystick(s)")

select_ids, start_ids = carregar_ids()
joysticks = {}
last_count = -1

while True:
    count = pygame.joystick.get_count()
    if count != last_count:
        joysticks.clear()
        for i in range(count):
            js   = pygame.joystick.Joystick(i)
            js.init()
            name = js.get_name().strip().lower()
            if name in select_ids and name in start_ids:
                joysticks[i] = {"obj": js, "name": name,
                                "select_id": select_ids[name],
                                "start_id":  start_ids[name],
                                "combo": False}
                print(f"[JOY] {name} mapeado")
            else:
                nb = js.get_numbuttons()
                sel_id = 6 if nb > 6 else (nb - 2 if nb >= 2 else 0)
                sta_id = 7 if nb > 7 else (nb - 1 if nb >= 1 else 0)
                joysticks[i] = {"obj": js, "name": name,
                                "select_id": sel_id,
                                "start_id":  sta_id,
                                "combo": False}
                print(f"[JOY] {name} sem mapeamento, fallback sel={sel_id} sta={sta_id}")
        last_count = count

    pygame.event.pump()

    for js_data in joysticks.values():
        try:
            js  = js_data["obj"]
            sel = js_data["select_id"]
            sta = js_data["start_id"]
            if js.get_button(sel) and js.get_button(sta):
                print(f"[MONITOR] combo detectado em {js_data['name']}")
                matar_emuladores()
                # Sai imediatamente: libera o lock e deixa o bash
                # detectar a morte do emulador e voltar ao ES
                sys.exit(0)
        except pygame.error:
            pass

    time.sleep(DELAY_LOOP)
END_PYTHON
    }

    iniciar_select_start_kill &
    MONITOR_PID=$!

    # 🕹️ Polling do emulador (mesmo padrão do fightcade.sh):
    # enquanto o emulador estiver vivo, aguarda. Assim que morrer
    # (Select+Start ou fechamento normal), sai na hora → volta pro ES.
    sleep 3
    while kill -0 "$EMU_PID" 2>/dev/null || pgrep -f "extra/eden/eden" >/dev/null 2>&1 || pgrep -x "sudachi" >/dev/null 2>&1; do
        sleep 0.3
    done

    echo "🎮 Emulador encerrado — voltando ao EmulationStation..."

    kill -9 "$MONITOR_PID" 2>/dev/null
    pkill -9 -f "$MONITOR_MARKER" 2>/dev/null
    rm -f "$LOCK_FILE"
    rm -f /userdata/system/.dev/configs/qr
    echo "" > /userdata/system/.dev/tempo_jogo.txt
    sleep 0.5
    rm -f /userdata/system/.dev/tempo_jogo.txt
    exit 0

fi
